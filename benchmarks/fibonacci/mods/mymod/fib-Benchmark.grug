count: number = 50

export run() {
    fib_numbers: List = _fib_list(count)
    assert_fib(fib_numbers)
}

local _fib_list(n: number) List {
    fib_list: List = List()

    memo: Dict = Dict()

    i: number = 0
    while i <= n {
        list_append(fib_list, _fib(i, memo))
        i = i + 1
    }

    return fib_list
}

local _fib(n: number, memo: Dict) number {
    if dict_has_key(memo, n) {
        return dict_get(memo, n)
    }

    result: number = n
    if n > 1 {
        result = _fib(n - 1, memo) + _fib(n - 2, memo)
    }

    dict_set(memo, n, result)
    return result
}
